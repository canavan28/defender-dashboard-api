# ─────────────────────────────────────────────
# AutoTask API Credentials
# Add these in Railway → your service → Variables
# ─────────────────────────────────────────────

# Your AutoTask zone URL (e.g. https://webservices24.autotask.net)
AUTOTASK_BASE_URL=https://webservicesN.autotask.net

# The username of your new API-only user
AUTOTASK_USERNAME=your_api_username_here

# The secret/API key generated for that user
AUTOTASK_SECRET=your_api_secret_here

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────

# A secret key your frontend sends with every request
# Generate with: openssl rand -hex 32
API_KEY=your_random_api_key_here

# Your Vercel frontend URL (comma-separated if multiple)
ALLOWED_ORIGINS=http://localhost:5173
